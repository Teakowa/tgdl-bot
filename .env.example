# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ALLOWED_USER_IDS=

# Cloudflare Queue
CF_ACCOUNT_ID=
CF_QUEUE_ID=
CF_API_TOKEN=
CF_QUEUE_BATCH_SIZE=5
CF_QUEUE_VISIBILITY_TIMEOUT_MS=900000
CF_QUEUE_PULL_INTERVAL_MS=3000

# Downloader
TDL_BIN=tdl
TDL_NAMESPACE=default
TDL_STORAGE=
TDL_LOGIN_REQUIRED=true
TDL_LOGIN_CHECK_ON_START=true
DOWNLOAD_DIR=./data/downloads
TDL_GROUP=true
TDL_SKIP_SAME=true
TDL_TASK_CONCURRENCY=1
TDL_THREAD_CONCURRENCY=4
DOWNLOADER_WORKERS=2
TASK_TIMEOUT_MINUTES=60

# Storage
SQLITE_PATH=./data/tasks.db

# Runtime
LOG_LEVEL=info
ENV=dev

