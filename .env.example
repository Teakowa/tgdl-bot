# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_LISTEN_ADDR=:8080
TELEGRAM_ALLOWED_USER_IDS=

# Cloudflare Queue + D1
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_QUEUE_ID=
CF_STATUS_QUEUE_ID=
CF_API_TOKEN=
CF_QUEUE_BATCH_SIZE=5
CF_QUEUE_VISIBILITY_TIMEOUT_MS=900000
CF_QUEUE_PULL_INTERVAL_MS=3000

# Downloader
TDL_BIN=/usr/local/bin/tdl
TDL_NAMESPACE=default
TDL_STORAGE=
TDL_LOGIN_REQUIRED=true
TDL_LOGIN_CHECK_ON_START=true
DOWNLOADER_WORKERS=1
TASK_TIMEOUT_MINUTES=180

# Runtime
LOG_LEVEL=info
ENV=dev

# Deployment (docker compose image tags)
BOT_IMAGE_TAG=latest
DOWNLOADER_IMAGE_TAG=latest
